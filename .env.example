# Copy this file to .env and fill in real values
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional fallback. When the Gemini call returns a quota / rate-limit error,
# the LLMClient transparently retries on Groq. Sign up at
# https://console.groq.com/keys (free tier, ~30 RPM on Llama 3.3 70B).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# "gemini" (default) or "groq" — which provider to try FIRST. The other is
# the fallback. Useful if Groq is faster/more reliable for your account.
LLM_PRIMARY=gemini

# Local model paths (auto-downloaded on first run)
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Paths
DATASET_PDF=datasets/dataset.pdf
INDEX_DIR=data/index
PARSED_STANDARDS=data/parsed_standards.json
WHITELIST=data/is_code_whitelist.json

# Offline mode (after running scripts/setup_offline.py once, set these to 1
# to guarantee inference.py never contacts the network):
HF_HUB_OFFLINE=
TRANSFORMERS_OFFLINE=
